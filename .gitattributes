# Normalize line endings to LF on checkin for all text files
* text=auto eol=lf

# Shell scripts and git hooks must stay LF
*.sh text eol=lf
.husky/* text eol=lf

# Lockfile: generated by Bun — treat as binary-ish (no diff, mark generated)
bun.lock linguist-generated=true -diff
bun.lockb binary linguist-generated=true -diff

# Generated router tree (if ever committed) should not pollute diffs
apps/web/src/routeTree.gen.ts linguist-generated=true -diff
