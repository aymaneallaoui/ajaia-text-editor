{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/app.ts",
  "exports": {
    ".": "./src/app.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "NODE_ENV=production bun run src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "bun test",
    "db:migrate": "bun run src/migrate.ts latest",
    "db:migrate:up": "bun run src/migrate.ts up",
    "db:migrate:down": "bun run src/migrate.ts down",
    "db:migrate:make": "bun run src/migrate.ts make"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "@t3-oss/env-core": "^0.13.11",
    "elysia": "^1.4.28",
    "kysely": "^0.29.2",
    "logixlysia": "^6.5.0",
    "pg": "^8.21.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "eslint": "^9.39.0",
    "typescript": "^5.9.0"
  }
}
