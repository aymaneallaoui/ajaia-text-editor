{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/app.ts",
  "exports": {
    ".": "./src/app.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "NODE_ENV=production bun run src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "bun test",
    "db:migrate": "bun run src/migrate.ts latest",
    "db:migrate:up": "bun run src/migrate.ts up",
    "db:migrate:down": "bun run src/migrate.ts down",
    "db:migrate:make": "bun run src/migrate.ts make",
    "db:seed": "bun run src/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1063.0",
    "@aws-sdk/s3-request-presigner": "^3.1063.0",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "@elysiajs/static": "^1.4.10",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@t3-oss/env-core": "^0.13.11",
    "elysia": "^1.4.28",
    "kysely": "^0.29.2",
    "logixlysia": "^6.5.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.7",
    "resend": "^6.12.4",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "eslint": "^9.39.0",
    "typescript": "^5.9.0"
  }
}
