
# -------------------------------- apps/api ----------------------------------
# PostgreSQL connection string (Kysely + pg)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app

# Node environment: development | production | test
NODE_ENV=development

# Log level (optional; defaults to debug in dev, info in prod): debug | info | warn | error
LOG_LEVEL=debug

# Port the API listens on
PORT=3001

# Cloudflare R2 (S3-compatible) object storage for document attachments.
# Create a bucket + S3 API token at https://dash.cloudflare.com → R2.
# Leave blank for DB-only work; infra/storage.ts only needs these when uploading.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=app-attachments
# Optional: public bucket / custom-domain base URL for public file links.
R2_PUBLIC_BASE_URL=

# Resend (transactional email) for welcome + document-shared notifications.
# Get an API key at https://resend.com → API Keys. Leave blank to disable email
# (the notification service no-ops + logs). EMAIL_FROM must be a verified sender.
RESEND_API_KEY=
EMAIL_FROM=Quire <onboarding@resend.dev>
# Base URL used for links inside emails (defaults to http://localhost:3001).
APP_URL=http://localhost:3001

# -------------------------------- apps/web ----------------------------------
# Only VITE_-prefixed vars are exposed to the client bundle.
VITE_API_URL=http://localhost:3001
